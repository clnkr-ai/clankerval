#!/usr/bin/make -f

include /usr/share/dpkg/pkg-info.mk

export CGO_ENABLED=0

VERSION := $(DEB_VERSION_UPSTREAM)

%:
	dh $@

override_dh_auto_build:
	go build -trimpath -ldflags '-s -w -X main.version=$(VERSION)' -o clankerval ./cmd/clankerval
	go build -trimpath -ldflags '-s -w -X main.version=$(VERSION)' -o evalfixture-agent ./internal/testfixture/evalfixture-agent

override_dh_auto_test:
	go test ./... -v
	set -eu; \
	tmp_repo="$$(mktemp -d)"; \
	trap 'rm -rf "$$tmp_repo"' EXIT; \
	mkdir -p "$$tmp_repo/testdata/evaluations/fixtures/dummy/001-basic"; \
	cp ./testdata/evaluations/fixtures/dummy/001-basic/note.txt \
		"$$tmp_repo/testdata/evaluations/fixtures/dummy/001-basic/note.txt"; \
	( \
		cd "$$tmp_repo" && \
		git init -q && \
		git config user.name debian-build && \
		git config user.email debian-build@example.com && \
		git add testdata/evaluations/fixtures/dummy/001-basic/note.txt && \
		git commit -q -m base && \
		"$(CURDIR)/clankerval" run --suite dummy \
			--evals-dir "$(CURDIR)/testdata/evaluations" \
			--binary "$(CURDIR)/evalfixture-agent" \
			--output-dir "$$tmp_repo/out" \
	)

override_dh_auto_install:
	:

override_dh_auto_clean:
	rm -f clankerval evalfixture-agent
	rm -rf .tmp

override_dh_dwz:
	# dwz fails on Go binaries
